{
  "name": "@formflowjs/react",
  "version": "0.1.0",
  "description": "Headless React adapter for FormFlow: hooks, providers, and renderless components that bind your own markup to the framework-agnostic @formflowjs/core engine.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": ["formflow", "strapi", "forms", "react", "headless", "form-renderer", "hooks"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hrahimi270/formflow-sdk.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/hrahimi270/formflow-sdk/tree/main/packages/react",
  "bugs": { "url": "https://github.com/hrahimi270/formflow-sdk/issues" },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:pkg": "publint",
    "clean": "rimraf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@formflowjs/core": "workspace:*"
  }
}
