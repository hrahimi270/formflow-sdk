{
  "name": "@formflowjs/vue",
  "version": "1.0.1",
  "description": "Headless Vue 3 adapter for FormFlow: composables and renderless components that bind your own markup to the framework-agnostic @formflowjs/core engine.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "formflow",
    "strapi",
    "forms",
    "vue",
    "headless",
    "form-renderer",
    "composables"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hrahimi270/formflow-sdk.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/hrahimi270/formflow-sdk/tree/main/packages/vue",
  "bugs": {
    "url": "https://github.com/hrahimi270/formflow-sdk/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:pkg": "publint",
    "clean": "rimraf dist .turbo"
  },
  "peerDependencies": {
    "vue": ">=3.4"
  },
  "dependencies": {
    "@formflowjs/core": "workspace:*"
  }
}
